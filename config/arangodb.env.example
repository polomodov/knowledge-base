# Local-development defaults only. `kb platform up` uses this file unless a gitignored
# config/arangodb.env exists — copy this to config/arangodb.env and set a real password
# before exposing ArangoDB beyond loopback. The compose file binds the port to 127.0.0.1.
ARANGO_ROOT_PASSWORD=knowledge-base-dev
ARANGO_PORT=8529

KB_ARANGO_URL=http://127.0.0.1:8529
KB_ARANGO_DATABASE=knowledge_base
KB_ARANGO_USER=root
KB_ARANGO_PASSWORD=knowledge-base-dev
